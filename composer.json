{
    "name": "endoguard/endoguard",
    "type": "project",
    "description": "EndoGuard: Internal & Embedded Cybersecurity Framework",
    "keywords": [
        "endoguard",
        "fraud-detection",
        "audit-trail",
        "analytics",
        "monitoring",
        "bot-detection",
        "antispam",
        "application-monitoring"
    ],
    "license": "AGPL-3.0+",
    "homepage": "https://www.endoguard.online",
    "authors": [
        {
            "name": "EndoGuard Security",
            "email": "team@endoguard.online",
            "homepage": "https://www.endoguard.online/"
        }
    ],
    "config": {
        "platform": {
            "php": "8.1.32"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.0",
        "ext-mbstring": "*",
        "bcosca/fatfree-core": "3.9.1",
        "phpmailer/phpmailer": "6.9.3",
        "ruler/ruler": "0.4.0",
        "matomo/device-detector": "6.5.0"
    },
    "autoload": {
        "psr-4": {
            "EndoGuard\\": "app/"
        }
    },
    "extra": {
        "paas": {
            "document-root": "/",
            "index-document": "index.php",
            "nginx-includes": ["nginx.conf"]
        }
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "3.10.3",
        "phpunit/phpunit": "10.5.62",
        "phpstan/phpstan": "2.1.37"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "compile": [
            "chmod 755 tmp",
            "chmod 740 config",
            "chmod 755 assets",
            "chmod 755 assets/rules/custom",
            "chmod 755 assets/rules/core",
            "chmod 755 assets/rules",
            "chmod 755 assets/logs",
            "chmod 755 assets/lists",
            "chmod 755 assets/dashboard",
            "chmod 640 composer.json",
            "chmod 640 composer.lock",
            "chmod -R 750 config"
        ]
    }
}
